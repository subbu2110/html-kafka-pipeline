# Data source — Wikipedia's "List of countries by population"
TARGET_URL=https://en.wikipedia.org/wiki/List_of_countries_by_population_(United_Nations)

# 0-based index of the HTML table to extract.
# Set TABLE_CSS_CLASS to prefer a table by CSS class instead (e.g. "wikitable").
TABLE_INDEX=0
TABLE_CSS_CLASS=wikitable

# Name for the destination DB table (sanitised automatically).
TABLE_NAME=countries_by_population

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=html-table-records
KAFKA_GROUP_ID=html-pipeline-consumer

# Database (MySQL) — DB_DSN is REQUIRED, no default is provided.
# Replace with your actual credentials before running.
DB_DRIVER=mysql
DB_DSN=<user>:<password>@tcp(<host>:3306)/<database>?parseTime=true

# Fetcher tuning
FETCH_TIMEOUT_SEC=30
FETCH_RETRIES=3

# Batch / flush
BATCH_SIZE=100
BATCH_FLUSH_MS=5000
